# Copy to .env and adjust as needed
DATABASE_URL="postgresql://binarylabs:binarylabs@localhost:5433/binarylabs?schema=public"

# Auth.js (NextAuth v5) — generate with: npx auth secret
AUTH_SECRET="change-me"
AUTH_TRUST_HOST="true"

# Seed admin credentials (used by prisma/seed.ts)
ADMIN_EMAIL="syed.asad@binarylabz.com"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Syed Asad Husain Zaidi"

# App
NEXT_PUBLIC_APP_NAME="Falak × Binary AI"

# Scheduled jobs — shared secret for /api/jobs/[job] (host cron sends x-cron-secret)
CRON_SECRET="change-me"

# Outbound email (optional — logged to console when unset)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Binary Labs <no-reply@binarylabz.com>"
# APP_URL="http://localhost:3000"

# Private document storage directory (defaults to ./var/files)
# FILE_STORAGE_DIR=""

# App-level field encryption (contractor payout details, HR identity numbers)
# Generate: openssl rand -hex 32
FIELD_ENCRYPTION_KEY="change-me-64-hex-chars"
