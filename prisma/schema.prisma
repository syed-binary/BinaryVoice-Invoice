// Binary Labs Invoicing — Prisma schema
// Money is stored as Decimal(12,2) in the invoice/estimate currency (AED by default).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth / users (multi-user, single company)
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  FINANCE
  HR
  MEMBER
  CONTRACTOR
  EMPLOYEE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notifications Notification[]
}

// ---------------------------------------------------------------------------
// Company settings (singleton row, id = "company")
// ---------------------------------------------------------------------------

model CompanySettings {
  id        String  @id @default("company")
  legalName String
  tradeName String?
  arabicName String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  emirate      String?
  country      String  @default("United Arab Emirates")
  poBox        String?

  phone   String?
  email   String?
  website String?
  logoUrl String?

  // Tax
  corporateTaxTrn String?
  vatTrn          String?
  vatEnabled      Boolean @default(false)
  defaultVatRate  Decimal @default(5) @db.Decimal(5, 2)
  defaultWithholdingRate Decimal @default(20) @db.Decimal(5, 2)

  // Bank
  bankName      String?
  accountName   String?
  iban          String?
  swift         String?
  accountNumber String?
  routingCode   String?

  // Invoice defaults / branding
  baseCurrency      String  @default("AED")
  invoicePrefix     String  @default("BL")
  estimatePrefix    String  @default("EST")
  nextInvoiceNumber Int     @default(1)
  nextEstimateNumber Int    @default(1)
  numberPadding     Int     @default(4)
  defaultTemplate   String  @default("modern")
  accentColor       String  @default("#4f46e5")
  defaultNotes      String?
  defaultTerms      String?
  defaultDueDays    Int     @default(14)

  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Clients
// ---------------------------------------------------------------------------

model Client {
  id          String   @id @default(cuid())
  displayName String
  companyName String?
  email       String?
  phone       String?
  trn         String?
  currency    String   @default("AED")

  billingAddress  String?
  shippingAddress String?
  notes           String?

  // Tax defaults for this client
  exportClient    Boolean  @default(false) // recipient outside UAE → VAT zero-rated
  withholdingRate Decimal? @db.Decimal(5, 2) // client deducts this WHT (e.g. Egypt 20%)

  customFields Json?

  invoices    Invoice[]
  estimates   Estimate[]
  engagements Engagement[]
  contracts   Contract[]

  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([displayName])
}

// ---------------------------------------------------------------------------
// Items / product catalog
// ---------------------------------------------------------------------------

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  unit        String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

// ---------------------------------------------------------------------------
// Invoices
// ---------------------------------------------------------------------------

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum DiscountType {
  PERCENT
  FIXED
}

model Invoice {
  id     String        @id @default(cuid())
  number String        @unique
  status InvoiceStatus @default(DRAFT)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  issueDate DateTime @default(now())
  dueDate   DateTime?
  currency  String   @default("AED")

  // Totals (computed & stored)
  subtotal      Decimal      @default(0) @db.Decimal(12, 2)
  discountType  DiscountType @default(FIXED)
  discountValue Decimal      @default(0) @db.Decimal(12, 2)
  discountAmount Decimal     @default(0) @db.Decimal(12, 2)
  vatEnabled    Boolean      @default(false)
  vatRate       Decimal      @default(5) @db.Decimal(5, 2)
  vatAmount     Decimal      @default(0) @db.Decimal(12, 2)
  withholdingEnabled Boolean @default(false)
  withholdingRate    Decimal @default(0) @db.Decimal(5, 2)
  withholdingAmount  Decimal @default(0) @db.Decimal(12, 2)
  total         Decimal      @default(0) @db.Decimal(12, 2)
  netPayable    Decimal      @default(0) @db.Decimal(12, 2)
  amountPaid    Decimal      @default(0) @db.Decimal(12, 2)

  // FX snapshot: document currency → base currency, frozen at issue.
  fxRate    Decimal @default(1) @db.Decimal(18, 8)
  baseTotal Decimal @default(0) @db.Decimal(12, 2)

  notes String?
  terms String?

  // Snapshot / branding
  templateId  String  @default("modern")
  accentColor String?

  customFields Json?

  lineItems LineItem[]
  payments  Payment[]

  // Origin (if converted from an estimate)
  estimateId String?   @unique
  estimate   Estimate? @relation(fields: [estimateId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([issueDate])
}

model LineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  itemId      String?
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)
  unit        String?
  discount    Decimal @default(0) @db.Decimal(12, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal @default(0) @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  // Optional link to a contractor engagement — enables actual (billed vs
  // paid) margin reporting per engagement.
  engagementId String?
  engagement   Engagement? @relation(fields: [engagementId], references: [id])

  @@index([invoiceId])
  @@index([engagementId])
}

// ---------------------------------------------------------------------------
// Estimates / quotes
// ---------------------------------------------------------------------------

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  CONVERTED
}

model Estimate {
  id     String         @id @default(cuid())
  number String         @unique
  status EstimateStatus @default(DRAFT)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  issueDate DateTime  @default(now())
  expiryDate DateTime?
  currency  String    @default("AED")

  subtotal      Decimal      @default(0) @db.Decimal(12, 2)
  discountType  DiscountType @default(FIXED)
  discountValue Decimal      @default(0) @db.Decimal(12, 2)
  discountAmount Decimal     @default(0) @db.Decimal(12, 2)
  vatEnabled    Boolean      @default(false)
  vatRate       Decimal      @default(5) @db.Decimal(5, 2)
  vatAmount     Decimal      @default(0) @db.Decimal(12, 2)
  withholdingEnabled Boolean @default(false)
  withholdingRate    Decimal @default(0) @db.Decimal(5, 2)
  withholdingAmount  Decimal @default(0) @db.Decimal(12, 2)
  total         Decimal      @default(0) @db.Decimal(12, 2)
  netPayable    Decimal      @default(0) @db.Decimal(12, 2)

  // FX snapshot: document currency → base currency, frozen at issue.
  fxRate    Decimal @default(1) @db.Decimal(18, 8)
  baseTotal Decimal @default(0) @db.Decimal(12, 2)

  notes String?
  terms String?

  templateId  String  @default("modern")
  accentColor String?

  customFields Json?

  lineItems EstimateLineItem[]
  invoice   Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([clientId])
}

model EstimateLineItem {
  id          String   @id @default(cuid())
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  itemId      String?
  description String
  quantity    Decimal  @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  unit        String?
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder   Int      @default(0)

  @@index([estimateId])
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime @default(now())
  method    String?
  reference String?
  notes     String?
  createdAt DateTime @default(now())

  // FX snapshot: payment currency → base currency, at payment date.
  fxRate     Decimal @default(1) @db.Decimal(18, 8)
  baseAmount Decimal @default(0) @db.Decimal(12, 2)

  @@index([invoiceId])
}

// ---------------------------------------------------------------------------
// Custom field definitions (dynamic fields for clients & invoices)
// ---------------------------------------------------------------------------

enum CustomFieldEntity {
  CLIENT
  INVOICE
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
}

model CustomFieldDefinition {
  id        String            @id @default(cuid())
  entity    CustomFieldEntity
  key       String
  label     String
  type      CustomFieldType   @default(TEXT)
  options   Json?
  required  Boolean           @default(false)
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())

  @@unique([entity, key])
}

// ---------------------------------------------------------------------------
// Foundations: numbering, documents, audit, notifications, FX
// ---------------------------------------------------------------------------

/// Generic atomic counter for document numbers (contracts, payables, payroll
/// runs, …). Invoice/estimate counters remain on CompanySettings for now.
model NumberSequence {
  key     String @id
  prefix  String
  next    Int    @default(1)
  padding Int    @default(4)
}

enum DocumentEntity {
  CLIENT
  CONTRACTOR
  EMPLOYEE
  CONTRACT
  INVOICE
  PAYABLE
  COMPANY
}

enum DocumentKind {
  GENERIC
  CONTRACT_PDF
  PASSPORT
  VISA
  EMIRATES_ID
  LABOUR_CARD
  W8BEN
  KYC_ID
  KYC_ADDRESS
  INSURANCE
  PAYSLIP
  OTHER
}

/// Universal file attachment + compliance vault. Files live in private
/// storage (lib/storage.ts) and are streamed through /api/files/[id] after a
/// capability check — never served from public/.
model Document {
  id         String         @id @default(cuid())
  entityType DocumentEntity
  entityId   String
  kind       DocumentKind   @default(GENERIC)

  fileName   String
  storageKey String @unique
  mimeType   String
  sizeBytes  Int

  expiryDate   DateTime? // drives expiry alerts (visa, EID, passport, W-8BEN)
  verifiedById String?
  verifiedAt   DateTime?

  uploadedById String
  archived     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([expiryDate])
}

/// Append-only. Diffs are shallow and redacted (lib/audit.ts) — never store
/// secrets, bank details or identity numbers here.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorRole  String
  action     String // e.g. "invoice.update", "payment.delete"
  entityType String
  entityId   String
  diff       Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // e.g. "invoice.overdue", "document.expiring"
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  emailedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

/// Daily FX rate cache (document currency → base). Manual entries override;
/// nightly fx-refresh job pulls ECB rates via frankfurter.app.
model FxRate {
  id     String   @id @default(cuid())
  base   String
  quote  String
  rate   Decimal  @db.Decimal(18, 8)
  date   DateTime @db.Date
  source String   @default("MANUAL") // MANUAL | ECB

  @@unique([base, quote, date])
}

// ---------------------------------------------------------------------------
// Contractors: global workforce, engagements, payables (inverse of invoices)
// ---------------------------------------------------------------------------

enum RateUnit {
  HOUR
  DAY
  MONTH
  FIXED
}

enum ContractorStatus {
  ONBOARDING
  ACTIVE
  INACTIVE
}

model Contractor {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  phone        String?
  country      String // ISO name or code — drives offer-letter clause packs later
  taxResidency String?
  entityName   String? // many contractors bill via their own LLC/Ltd
  taxId        String?
  vatRegistered Boolean @default(false)
  address      String?

  currency      String  @default("USD")
  payoutMethod  String? // BANK | WISE | PAYONEER | OTHER
  payoutDetails String? // encrypted JSON blob (lib/crypto.ts) — IBAN/Wise email/…

  defaultCostRate Decimal? @db.Decimal(12, 2)
  defaultRateUnit RateUnit @default(DAY)

  status ContractorStatus @default(ONBOARDING)
  userId String? @unique // portal login (Phase 4)

  customFields Json?
  notes        String?
  archived     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  engagements Engagement[]
  payables    ContractorInvoice[]
  payouts     Payout[]
  contracts   Contract[]

  @@index([name])
  @@index([status])
}

enum Ir35Status {
  NOT_APPLICABLE
  INSIDE
  OUTSIDE
  UNDETERMINED
}

/// A contractor placed on client work (or internal lab work when clientId
/// is null). Cost vs bill rates drive margin reporting.
model Engagement {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
  clientId     String?
  client       Client?    @relation(fields: [clientId], references: [id])

  title     String // e.g. "Senior ML Engineer @ Acme"
  startDate DateTime
  endDate   DateTime?

  rateUnit     RateUnit
  costRate     Decimal  @db.Decimal(12, 2)
  costCurrency String
  billRate     Decimal? @db.Decimal(12, 2)
  billCurrency String?

  capacity Decimal? @db.Decimal(5, 2) // FTE fraction, for utilization

  ir35Status Ir35Status @default(NOT_APPLICABLE) // UK contractor at UK client
  ir35Notes  String? // SDS reference; the SDS PDF lives in the Document vault

  contractId String? // signed contractor agreement / SOW covering this work
  contract   Contract? @relation(fields: [contractId], references: [id])

  status    String   @default("ACTIVE") // ACTIVE | ENDED
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payables  ContractorInvoice[]
  lineItems LineItem[]

  @@index([contractorId])
  @@index([clientId])
}

enum PayableStatus {
  RECEIVED
  APPROVED
  SCHEDULED
  PAID
  REJECTED
}

/// A contractor's invoice to us — the payables mirror of Invoice.
model ContractorInvoice {
  id             String     @id @default(cuid())
  internalNumber String     @unique // NumberSequence "payable"
  contractorRef  String? // the contractor's own invoice number
  contractorId   String
  contractor     Contractor @relation(fields: [contractorId], references: [id])
  engagementId   String?
  engagement     Engagement? @relation(fields: [engagementId], references: [id])

  periodStart DateTime?
  periodEnd   DateTime?
  issueDate   DateTime  @default(now())
  dueDate     DateTime?

  currency  String
  fxRate    Decimal @default(1) @db.Decimal(18, 8)
  subtotal  Decimal @default(0) @db.Decimal(12, 2)
  total     Decimal @default(0) @db.Decimal(12, 2)
  baseTotal Decimal @default(0) @db.Decimal(12, 2)

  status       PayableStatus @default(RECEIVED)
  approvedById String?
  approvedAt   DateTime?
  rejectedReason String?

  sourceDocumentId String? // uploaded PDF from the contractor (Document id)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lines  ContractorInvoiceLine[]
  payout Payout?

  @@index([status])
  @@index([contractorId])
}

model ContractorInvoiceLine {
  id          String            @id @default(cuid())
  payableId   String
  payable     ContractorInvoice @relation(fields: [payableId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal           @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal           @default(0) @db.Decimal(12, 2)
  unit        String?
  lineTotal   Decimal           @default(0) @db.Decimal(12, 2)
  sortOrder   Int               @default(0)

  @@index([payableId])
}

enum PayoutRunStatus {
  DRAFT
  APPROVED
  PAID
}

/// Track-only batch mirroring what was sent via Wise/bank.
model PayoutRun {
  id        String          @id @default(cuid())
  number    String          @unique // NumberSequence "payout-run"
  name      String?
  status    PayoutRunStatus @default(DRAFT)
  paidDate  DateTime?
  method    String?
  reference String?
  totalBase Decimal         @default(0) @db.Decimal(12, 2)

  approvedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payouts Payout[]
}

// ---------------------------------------------------------------------------
// Contracts: templates, jurisdiction clause packs, e-sign
// ---------------------------------------------------------------------------

enum ContractType {
  MSA
  SOW
  NDA
  CONTRACTOR_AGREEMENT
  OFFER_LETTER
  EMPLOYMENT
  AMENDMENT
  OTHER
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  EXPIRED
  TERMINATED
}

enum RenewalType {
  NONE
  AUTO_RENEW
  MANUAL
}

enum ClauseCategory {
  ENGAGEMENT_STATUS
  TAX_WITHHOLDING
  IP_ASSIGNMENT
  CONFIDENTIALITY
  DATA_PROTECTION
  TERMINATION
  NON_SOLICIT
  DISPUTE_LAW
  COMPLIANCE
  PAYMENT
  OTHER
}

/// Markdown body with {{merge.fields}} (lib/contracts/merge.ts).
model ContractTemplate {
  id           String       @id @default(cuid())
  name         String
  type         ContractType
  body         String
  variables    Json? // declared custom variables beyond the built-in paths
  jurisdiction String? // optional ISO country hint
  archived     Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

/// Jurisdiction-aware clause library. jurisdiction "*" = global pack; ISO
/// codes ("GB", "IN", "AE") select country packs for offer letters and
/// contractor agreements. AI-drafted clauses stay flagged until counsel
/// review (reviewedBy/reviewedAt) — the UI warns on unreviewed clauses.
model Clause {
  id           String         @id @default(cuid())
  jurisdiction String
  category     ClauseCategory
  title        String
  body         String // markdown with merge fields
  mandatory    Boolean        @default(true) // auto-included for that jurisdiction
  sortOrder    Int            @default(0)
  version      Int            @default(1)
  reviewedBy   String?
  reviewedAt   DateTime?
  archived     Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([jurisdiction, category])
}

model Contract {
  id     String         @id @default(cuid())
  number String         @unique // NumberSequence "contract"
  type   ContractType
  status ContractStatus @default(DRAFT)
  title  String

  // Exactly one counterparty (employee joins in the HR phase).
  clientId     String?
  client       Client?     @relation(fields: [clientId], references: [id])
  contractorId String?
  contractor   Contractor? @relation(fields: [contractorId], references: [id])

  // SOW under MSA, amendments under their parent.
  parentId String?
  parent   Contract?  @relation("ContractParent", fields: [parentId], references: [id])
  children Contract[] @relation("ContractParent")

  effectiveDate    DateTime?
  endDate          DateTime?
  renewalType      RenewalType @default(NONE)
  noticePeriodDays Int?

  value     Decimal? @db.Decimal(12, 2)
  currency  String   @default("AED")
  fxRate    Decimal  @default(1) @db.Decimal(18, 8)
  baseValue Decimal? @db.Decimal(12, 2)

  templateId   String?
  body         String // working draft (markdown)
  bodySnapshot String? // frozen at send — what signatories actually sign
  bodyHash     String? // sha256 of bodySnapshot — signature integrity

  customFields Json?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  versions    ContractVersion[]
  signatories ContractSignatory[]
  engagements Engagement[]

  @@index([status])
  @@index([endDate])
  @@index([clientId])
  @@index([contractorId])
}

model ContractVersion {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  version     Int
  body        String
  changeNote  String?
  createdById String
  createdAt   DateTime @default(now())

  @@unique([contractId, version])
}

/// Public signing link: /sign/[token]. Click-to-sign captures typed name +
/// IP + user agent + timestamp against the frozen body hash.
model ContractSignatory {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  name       String
  email      String
  order      Int      @default(0)

  token         String    @unique
  viewedAt      DateTime?
  signedAt      DateTime?
  signatureName String?
  ip            String?
  userAgent     String?
  createdAt     DateTime  @default(now())
}

model Payout {
  id                  String             @id @default(cuid())
  payoutRunId         String?
  payoutRun           PayoutRun?         @relation(fields: [payoutRunId], references: [id])
  contractorId        String
  contractor          Contractor         @relation(fields: [contractorId], references: [id])
  contractorInvoiceId String?            @unique
  contractorInvoice   ContractorInvoice? @relation(fields: [contractorInvoiceId], references: [id])

  amount     Decimal  @db.Decimal(12, 2)
  currency   String
  fxRate     Decimal  @default(1) @db.Decimal(18, 8)
  baseAmount Decimal  @default(0) @db.Decimal(12, 2)
  feeAmount  Decimal? @db.Decimal(12, 2) // Wise/bank fee, for true cost

  paidDate  DateTime?
  reference String?
  createdAt DateTime  @default(now())

  @@index([contractorId])
}
